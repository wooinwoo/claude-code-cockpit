{
  "productName": "Cockpit",
  "version": "1.6.0",
  "identifier": "com.cockpit.dashboard",
  "build": {
    "frontendDist": "http://localhost:3847"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cockpit",
        "width": 1400,
        "height": 900,
        "center": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
