{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["lib/**/*.js", "routes/**/*.js"],
  "exclude": ["node_modules", "vendor", "src-tauri"]
}
